    <circle cx="20" cy="20" r="10" stroke="url(#si1)" strokeWidth="2"/>
    <circle cx="20" cy="20" r="4" fill="url(#si1)"/>
    <path d="M20 4 L20 10 M20 30 L20 36 M4 20 L10 20 M30 20 L36 20" stroke="url(#si1)" strokeWidth="2" strokeLinecap="round"/>
    <path d="M7.5 7.5 L11.5 11.5 M28.5 28.5 L32.5 32.5 M32.5 7.5 L28.5 11.5 M11.5 28.5 L7.5 32.5" stroke="url(#si1)" strokeWidth="1.5" strokeLinecap="round"/>
    <defs><linearGradient id="si1" x1="0" y1="0" x2="40" y2="40" gradientUnits="userSpaceOnUse"><stop stopColor="#4F46E5"/><stop offset="1" stopColor="#06B6D4"/></linearGradient></defs>
  </svg>
)

